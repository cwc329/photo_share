# ── Facebook Login for Business ──────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_REDIRECT_URI=http://localhost:8001/auth/callback

# ── Instagram Business Login ─────────────────────────────────
META_IG_APP_ID=your_instagram_app_id
META_IG_APP_SECRET=your_instagram_app_secret
META_IG_REDIRECT_URI=http://localhost:8001/auth/ig/callback

# ── General ──────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_random_secret_key
DATABASE_URL=sqlite:////data/photo_share.db

# Fernet 金鑰
# 產生：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# ── URLs（開發環境） ───────────────────────────────────────────
# Meta App Dashboard 裡 Valid OAuth Redirect URIs 必須與這裡一致
FRONTEND_URL=http://localhost:5173
SERVER_BASE_URL=http://localhost:8001

# ── Docker 對外 port（依環境調整）──────────────────────────────
# docker-compose.yml 會讀取這些變數決定要綁定到 host 的哪個位址/port
# 開發時若希望區網可連，可把 *_BIND 改成 0.0.0.0
FRONTEND_BIND=127.0.0.1
FRONTEND_PORT=3000
BACKEND_BIND=127.0.0.1
BACKEND_PORT=8001

# ── Cookie（開發環境） ──────────────────────────────────────────
# 開發環境：COOKIE_DOMAIN 留空（cookie 限定 localhost）
# 正式環境：COOKIE_DOMAIN=.example.com（讓 photo-share. 與 api. 子域名共享 cookie）
COOKIE_DOMAIN=
COOKIE_SECURE=false

# ── 正式環境範例（部署時複製並修改） ──────────────────────────────
# META_REDIRECT_URI=
# META_IG_REDIRECT_URI=
# FRONTEND_URL=
# SERVER_BASE_URL=
# COOKIE_DOMAIN=
# COOKIE_SECURE=true

# ── 前端（Vite） ──────────────────────────────────────────────
# 開發：http://localhost:8001
VITE_API_BASE_URL=http://localhost:8001
